---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const topics = [
	{ name: 'Machine Learning', items: ['Neural Networks 101', 'Model Training Log', 'ML Project A'] },
	{ name: 'Embedded Systems', items: ['ESP32 Troubleshooting', 'Shelly Scripting', 'Arduino Bench Notes'] },
	{ name: 'Sports', items: [] },
	{ name: 'Travels', items: [] }
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1400px;
				margin: 0 auto;
				padding: 2em 0; /* Removed side padding to keep items flush */
			}

			.welcome-bar {
				padding: 1rem 2rem;
				border-bottom: 1px solid #e5e7eb;
				color: #4b5563;
				font-size: 0.9rem;
			}

			.layout-container {
				display: flex;
				align-items: flex-start;
				margin-top: 2rem;
			}

			/* Sidebar: Flushed to the left */
			aside {
				width: 280px;
				background-color: #f6f3ef;
				padding: 0rem;
				min-height: 100vh;
				flex-shrink: 0;
			}

			.sidebar-title {
				font-size: 2.2rem;
				font-weight: 800;
				margin-bottom: 1.5rem;
				letter-spacing: -0.02em;
			}

			details {
				margin-bottom: 1.2rem;
			}

			summary {
				list-style: none;
				font-weight: 700;
				font-size: 1.1rem;
				cursor: pointer;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			summary::after {
				content: '▼';
				font-size: 0.7rem;
			}

			.sidebar-list {
				list-style: none;
				padding: 0.8rem 0 0 0.5rem;
				margin: 0;
			}

			.sidebar-list li {
				margin-bottom: 0.5rem;
			}

			.sidebar-list li a {
				color: #2563eb;
				text-decoration: underline;
				font-size: 0.9rem;
			}

			/* Main Content: 3 Column Grid */
			.content-area {
				flex-grow: 1;
				padding: 0 4rem;
			}

			.featured-title {
				font-size: 2.2rem;
				font-weight: 800;
				margin-bottom: 2.5rem;
			}

			.thumbnail-grid {
				display: grid;
				/* Forced 3-column layout */
				grid-template-columns: repeat(3, 1fr); 
				gap: 3rem;
			}

			.card {
				text-decoration: none;
				color: inherit;
			}

			.thumb-box {
				background-color: #cccccc;
				aspect-ratio: 16 / 10;
				border-radius: 4px;
				display: flex;
				align-items: center;
				justify-content: center;
				color: #666;
				font-size: 0.85rem;
				margin-bottom: 1rem;
			}

			.card-text {
				font-weight: 600;
				font-size: 1.1rem;
				color: #111827;
			}
		</style>
	</head>
	<body>
		<div class="watermark">UNDER CONSTRUCTION</div>
		<Header />
		
		<main class="layout-container">
			<aside>
				<h1 class="sidebar-title">Blog Topics</h1>
				{topics.map((topic) => (
					<details open={topic.items.length > 0}>
						<summary>{topic.name}</summary>
						<ul class="sidebar-list">
							{topic.items.map((item) => (
								<li><a href="#">{item}</a></li>
							))}
						</ul>
					</details>
				))}
			</aside>

			<section class="content-area">
				<h1 class="featured-title">Featured Notes</h1>
				<div class="thumbnail-grid">
					{[1, 2, 3, 4, 5, 6].map((i) => (
						<a href="#" class="card">
							<div class="thumb-box">Thumbnail {i}</div>
							<div class="card-text">Latest Project Update #{i}</div>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>